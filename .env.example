# ──────────────────────────────────────────────
# IRIS Environment Variables
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# [REQUIRED] Google Gemini API Key
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# [OPTIONAL] Mem0 Cloud API Key (leave blank to use local Mem0)
# Get it at: https://app.mem0.ai/settings/api-keys
MEM0_API_KEY=

# [OPTIONAL] ElevenLabs TTS API Key
# Get it at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# User identity for Mem0 memory namespace
IRIS_USER_ID=iris_user_01
IRIS_USER_NAME=YourName
